# =============================================================================
# stack.env — Klartext-Konfiguration (keine Secrets)
# =============================================================================
# Secrets kommen aus Infisical (Projekt: novabrands-mgmt, Pfad: /novabrands-mgmt)
# Start: infisical run --env=prod --path=/novabrands-mgmt -- docker compose up -d
# =============================================================================

# Domains
DOMAIN=novabrands.org
OP_HOSTNAME=openproject.novabrands.org
NC_HOSTNAME=cloud.novabrands.org
COLLABORA_HOSTNAME=office.novabrands.org
TZ=Europe/Berlin

# OpenProject
OP_DB_NAME=openproject
OP_DB_USER=openproject
OP_RAILS_MIN_THREADS=4
OP_RAILS_MAX_THREADS=16

# Nextcloud
NC_DB_NAME=nextcloud
NC_DB_USER=nextcloud
NC_ADMIN_USER=admin

# Collabora
COLLABORA_ADMIN_USER=admin

# SMTP (Host/Port/From — Credentials in Infisical)
SMTP_PORT=465
SMTP_FROM=noreply@novabrands.org
SMTP_DOMAIN=novabrands.org
