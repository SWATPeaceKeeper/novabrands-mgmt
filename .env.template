# =============================================================================
# .env.template — Documentation Stack
# =============================================================================
# Diese Datei ist SICHER fuer Git (keine echten Secrets).
# Secrets werden ueber pass:// Referenzen aus Proton Pass aufgeloest.
#
# Verwendung:
#   pass-cli inject --in-file .env.template --out-file .env --file-mode 0600
#
# Voraussetzung: Proton Pass Vault "Novabrands Infra" mit den Items:
#   - OpenProject DB      (password)
#   - OpenProject App     (custom field: secret_key_base)
#   - Nextcloud DB        (password)
#   - Nextcloud Admin     (password)
#   - Redis               (password)
#   - Coder DB            (password)
#   - Collabora Admin     (password)
#   - Traefik Dashboard   (password)
#   - SMTP                (username, password)
#   - Hetzner Cloud       (password = API Token)
# =============================================================================

# -------------------------------------------------------------------
# Domains (Klartext — keine Secrets)
# -------------------------------------------------------------------
DOMAIN=novabrands.de
OP_HOSTNAME=openproject.novabrands.de
NC_HOSTNAME=cloud.novabrands.de
COLLABORA_HOSTNAME=office.novabrands.de
CODER_HOSTNAME=coder.novabrands.de
TZ=Europe/Berlin

# -------------------------------------------------------------------
# OpenProject (Config)
# -------------------------------------------------------------------
OP_DB_NAME=openproject
OP_DB_USER=openproject
OP_RAILS_MIN_THREADS=4
OP_RAILS_MAX_THREADS=16

# -------------------------------------------------------------------
# Nextcloud (Config)
# -------------------------------------------------------------------
NC_DB_NAME=nextcloud
NC_DB_USER=nextcloud
NC_ADMIN_USER=admin

# -------------------------------------------------------------------
# Coder (Config)
# -------------------------------------------------------------------
CODER_DB_NAME=coder
CODER_DB_USER=coder

# -------------------------------------------------------------------
# Collabora (Config)
# -------------------------------------------------------------------
COLLABORA_ADMIN_USER=admin

# -------------------------------------------------------------------
# SMTP (Config — Host/Port/From hier, Credentials unten)
# -------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=noreply@novabrands.de
SMTP_DOMAIN=novabrands.de

# -------------------------------------------------------------------
# Secrets (aufgeloest durch pass-cli inject)
# -------------------------------------------------------------------
OP_DB_PASSWORD={{ pass://Novabrands Infra/OpenProject DB/password }}
OP_SECRET_KEY_BASE={{ pass://Novabrands Infra/OpenProject App/secret_key_base }}
NC_DB_PASSWORD={{ pass://Novabrands Infra/Nextcloud DB/password }}
NC_REDIS_PASSWORD={{ pass://Novabrands Infra/Redis/password }}
NC_ADMIN_PASSWORD={{ pass://Novabrands Infra/Nextcloud Admin/password }}
CODER_DB_PASSWORD={{ pass://Novabrands Infra/Coder DB/password }}
HCLOUD_TOKEN={{ pass://Novabrands Infra/Hetzner Cloud/password }}
COLLABORA_ADMIN_PASSWORD={{ pass://Novabrands Infra/Collabora Admin/password }}
SMTP_USER={{ pass://Novabrands Infra/SMTP/username }}
SMTP_PASSWORD={{ pass://Novabrands Infra/SMTP/password }}
TRAEFIK_DASHBOARD_PASSWORD={{ pass://Novabrands Infra/Traefik Dashboard/password }}

# -------------------------------------------------------------------
# Traefik Auth (generiert von setup.sh aus TRAEFIK_DASHBOARD_PASSWORD)
# -------------------------------------------------------------------
TRAEFIK_DASHBOARD_AUTH=__GENERATED_BY_SETUP__
